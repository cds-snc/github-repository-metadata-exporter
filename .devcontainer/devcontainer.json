{
	"name": "github-repository-metadata-exporter",
	"image": "mcr.microsoft.com/vscode/devcontainers/base:bullseye@sha256:c4a714ff46f28f8502a69d18756b5d9d7e49c2cc3e5ca166b5f74ff80d1792d0",
	"features": {
		"node": {
			"version": "lts"
		}
	},
	"containerEnv": {
		"SHELL": "/bin/zsh"
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"redhat.vscode-yaml",
				"github.copilot"
			]
		},
